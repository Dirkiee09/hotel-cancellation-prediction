htmlcov/

# Gradio
.gradio/

# Temp
.tmp/

# Generated outputs (recreated by `make train` / `make benchmark`)
artifacts/*
!artifacts/.gitkeep
reports/*
!reports/.gitkeep
reports/figures/*
!reports/figures/.gitkeep
data/*.csv
!data/.gitkeep
# Live-demo prediction stores (sqlite/CSV written at serving time, never tracked)
data/predictions/
*.sqlite
# Thesis manuscripts do not belong in the repo root
/*.pdf

# Live prediction log (written by FastAPI /predict, read by Power BI)
data/predictions/

# Secrets
.env
.env.*
!.env.example

# Thesis source manuscripts (kept locally, not in version control)
Revisions of Predicting Hotel Booking Cancellations_ A Machine Learning Approach.pdf
*.docx
