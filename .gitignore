# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Virtual environment
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Local AI assistant settings (machine-specific)
.claude/settings.local.json

# Jupyter
.ipynb_checkpoints/
.jupyter_runtime/

# Tool caches
.pytest_cache/
.pytest_tmp/
.mypy_cache/
